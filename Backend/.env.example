DJANGO_SECRET_KEY=change-this-secret-key
DJANGO_DEBUG=True
APP_PUBLIC_URL=https://your-northflank-service.code.run
ALLOWED_HOSTS=127.0.0.1,localhost,.code.run,infaanwebdesign.vercel.app
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://infaanwebdesign.vercel.app,http://localhost:5173
CORS_ALLOWED_ORIGIN_REGEXES=https://.*\\.vercel\\.app,https://.*\\.code\\.run
CSRF_TRUSTED_ORIGINS=https://*.code.run,https://infaanwebdesign.vercel.app,http://127.0.0.1:8000,http://localhost:5173
DATABASE_URL=postgresql://user:password@host:5432/database
SEED_INFAAN_DATA=true
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=yourgmail@gmail.com
EMAIL_HOST_PASSWORD=your-google-app-password
DEFAULT_FROM_EMAIL=yourgmail@gmail.com
SYSTEM_SUBSCRIPTION_API_URL=https://your-northflank-service.code.run/api
